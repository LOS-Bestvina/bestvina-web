{
  "name": "bestvina-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "prerender": "bun prerender.ts",
    "generate": "bun run prerender && nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "deploy-test": "wrangler pages deploy .output/public --project-name bestvina-test",
    "publish-test": "bun run generate && bun run deploy-test"
  },
  "dependencies": {
    "@nuxt/content": "^3.13.0",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/hints": "1.0.3",
    "@nuxt/image": "2.0.0",
    "@nuxt/scripts": "^1.0.4",
    "@nuxt/ui": "^4.7.1",
    "@types/node": "^25.6.0",
    "@vueuse/core": "^14.2.1",
    "@vueuse/motion": "^3.0.3",
    "eslint": "^10.2.1",
    "image-size": "^2.0.2",
    "nuxt": "^4.4.4",
    "nuxt-studio": "^1.7.0",
    "typescript": "^6.0.3",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@iconify-json/carbon": "^1.2.20",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/lucide": "^1.2.104",
    "@iconify-json/material-symbols": "^1.2.69",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/proicons": "^1.2.19",
    "@iconify-json/simple-icons": "^1.2.80",
    "@iconify-json/svg-spinners": "^1.2.4",
    "@playwright/test": "^1.59.1",
    "@vue/test-utils": "^2.4.9",
    "rollup-plugin-visualizer": "^7.0.1",
    "wrangler": "^4.86.0"
  }
}
